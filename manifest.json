{
  "manifest_version": 3,
  "name": "BlackRoad Command Center",
  "version": "2.0.0",
  "description": "BlackRoad Command Center \u2014 Live fleet monitoring, service search, and quick access to all BlackRoad OS services. Powered by Prism.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "BlackRoad Command Center"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "https://prism.blackroad.io/*"
  ]
}